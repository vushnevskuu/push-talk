# Public site URL (no trailing slash) — sitemap, canonical URLs, JSON-LD
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Optional: “buy me a coffee” / Ko-fi / Patreon — shows Support link in footer and on /success
# NEXT_PUBLIC_DONATION_URL=https://www.buymeacoffee.com/yourhandle

# Optional: Google Search Console HTML tag verification (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: GA4 measurement ID (G-XXXXXXXXXX) — analytics per marketing stack
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostgreSQL (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Airwallex — use https://api-demo.airwallex.com in sandbox; set AIRWALLEX_API_BASE accordingly
AIRWALLEX_API_BASE=https://api-demo.airwallex.com
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
# Required when your scoped key spans multiple accounts
# AIRWALLEX_LOGIN_AS=

AIRWALLEX_LEGAL_ENTITY_ID=
AIRWALLEX_LINKED_PAYMENT_ACCOUNT_ID=
# Monthly recurring price (USD 10) — Billing → Products & Prices
AIRWALLEX_RECURRING_PRICE_ID=
# Optional: one-time USD 1 “trial start” price. If checkout creation fails, remove this and use only recurring + trial.
AIRWALLEX_TRIAL_SETUP_PRICE_ID=

# Webhook signing secret from Airwallex dashboard (required in production)
AIRWALLEX_WEBHOOK_SECRET=

# Optional: shown on landing for GitHub links (default: public main repo)
NEXT_PUBLIC_GITHUB_REPO=vushnevskuu/push-talk

# Optional: footer byline (default in code: Alexey Vishnevsky)
# NEXT_PUBLIC_SITE_AUTHOR_NAME=Alexey Vishnevsky
# NEXT_PUBLIC_SITE_AUTHOR_LINKEDIN=https://www.linkedin.com/in/vushnevskuu/

# Optional: override hidden /gate login (defaults are embedded base64 in src/server/crewGate.ts)
# VOICEINSERT_CREW_LOGIN=
# VOICEINSERT_CREW_PASSWORD=
