{
  "name": "voiceinsert-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:free": "sh -c 'for p in $(lsof -ti :3000 2>/dev/null); do kill $p 2>/dev/null; done; sleep 0.5; for p in $(lsof -ti :3000 2>/dev/null); do kill -9 $p 2>/dev/null; done; exit 0'",
    "predev": "npm run dev:free",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "prisma": "^6.3.1",
    "typescript": "^5.7.3"
  }
}
